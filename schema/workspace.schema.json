{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarbou3i.example/schema/local-workspace-v3.schema.json",
  "title": "Jarbou3i Local Workspace v3",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "format_version", "workspace_id", "repository_revision", "metadata", "analysis_identity", "imported_revision_id", "head_revision_id", "revisions", "working_draft", "audit_events", "review_ledger", "resolution_ledger"],
  "properties": {
    "format": { "const": "jarbou3i-local-workspace" },
    "format_version": { "const": 3 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "repository_revision": { "type": "integer", "minimum": 1 },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "created_at", "updated_at", "archived_at"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "archived_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "analysis_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lens_id", "contract_id", "schema_version", "language", "analysis_id"],
      "properties": {
        "lens_id": { "enum": ["strategic", "biopolitical"] },
        "contract_id": { "type": "string", "minLength": 1 },
        "schema_version": { "type": "string", "minLength": 1 },
        "language": { "enum": ["ar", "en", "fr"] },
        "analysis_id": { "type": "string" }
      }
    },
    "imported_revision_id": { "type": "string", "minLength": 1 },
    "head_revision_id": { "type": "string", "minLength": 1 },
    "revisions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/revision" }
    },
    "working_draft": { "$ref": "#/$defs/draft" },
    "audit_events": {
      "type": "array",
      "items": { "$ref": "#/$defs/auditEvent" }
    },
    "review_ledger": { "$ref": "#/$defs/reviewLedger" },
    "resolution_ledger": { "$ref": "#/$defs/resolutionLedger" }
  },
  "$defs": {
    "checksum": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "payload": { "type": "object" },
    "revision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revision_id", "parent_revision_id", "kind", "created_at", "payload_checksum", "canonical_payload"],
      "properties": {
        "revision_id": { "type": "string", "minLength": 1 },
        "parent_revision_id": { "type": ["string", "null"] },
        "kind": { "enum": ["imported_canonical", "committed_resolution"] },
        "created_at": { "type": "string", "format": "date-time" },
        "payload_checksum": { "$ref": "#/$defs/checksum" },
        "canonical_payload": { "$ref": "#/$defs/payload" },
        "resolution_record_id": { "type": "string", "minLength": 1 }
      }
    },
    "draft": {
      "type": "object",
      "additionalProperties": false,
      "required": ["draft_id", "base_revision_id", "updated_at", "payload_checksum", "canonical_payload", "dirty"],
      "properties": {
        "draft_id": { "type": "string", "minLength": 1 },
        "base_revision_id": { "type": "string", "minLength": 1 },
        "updated_at": { "type": "string", "format": "date-time" },
        "payload_checksum": { "$ref": "#/$defs/checksum" },
        "canonical_payload": { "$ref": "#/$defs/payload" },
        "dirty": { "type": "boolean" }
      }
    },
    "auditEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_id", "type", "occurred_at", "revision_id"],
      "properties": {
        "event_id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "occurred_at": { "type": "string", "format": "date-time" },
        "revision_id": { "type": "string", "minLength": 1 }
      }
    },
    "reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewer_id", "display_name", "identity_assurance"],
      "properties": {
        "reviewer_id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 },
        "identity_assurance": { "const": "local_assertion" }
      }
    },
    "reviewTask": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plan_task_id", "phase", "reason_code", "target_type", "target_id", "owner_id", "canonical_path"],
      "properties": {
        "plan_task_id": { "type": "string" },
        "phase": { "type": "string", "minLength": 1 },
        "reason_code": { "type": "string", "minLength": 1 },
        "target_type": { "type": "string", "minLength": 1 },
        "target_id": { "type": "string", "minLength": 1 },
        "owner_id": { "type": "string" },
        "canonical_path": { "type": "string" }
      }
    },
    "reviewEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_id", "sequence", "type", "occurred_at", "previous_event_hash", "workspace_id", "repository_revision_before", "draft_checksum", "task_key", "task", "reviewer", "rationale", "note", "waiver", "event_hash"],
      "properties": {
        "event_id": { "type": "string", "minLength": 1 },
        "sequence": { "type": "integer", "minimum": 1 },
        "type": { "enum": ["task_started", "task_completed", "task_waived", "task_reopened", "note_added"] },
        "occurred_at": { "type": "string", "format": "date-time" },
        "previous_event_hash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "workspace_id": { "type": "string", "minLength": 1 },
        "repository_revision_before": { "type": "integer", "minimum": 1 },
        "draft_checksum": { "$ref": "#/$defs/checksum" },
        "task_key": { "type": "string", "pattern": "^rt_[a-f0-9]{64}$" },
        "task": { "$ref": "#/$defs/reviewTask" },
        "reviewer": { "$ref": "#/$defs/reviewer" },
        "rationale": { "type": "string" },
        "note": { "type": "string" },
        "waiver": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["scope", "accepted_risk", "expires_at"],
              "properties": {
                "scope": { "type": "string", "minLength": 1 },
                "accepted_risk": { "type": "string", "minLength": 1 },
                "expires_at": { "type": ["string", "null"], "format": "date-time" }
              }
            }
          ]
        },
        "event_hash": { "$ref": "#/$defs/checksum" }
      }
    },
    "reviewLedger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "format_version", "created_at", "head_event_hash", "events"],
      "properties": {
        "format": { "const": "jarbou3i-operational-review-ledger" },
        "format_version": { "const": 1 },
        "created_at": { "type": "string", "format": "date-time" },
        "head_event_hash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "events": { "type": "array", "items": { "$ref": "#/$defs/reviewEvent" } }
      }
    },
    "resolutionValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["valid", "error_count", "warning_count", "errors"],
      "properties": {
        "valid": { "const": true },
        "error_count": { "const": 0 },
        "warning_count": { "type": "integer", "minimum": 0 },
        "errors": { "type": "array", "maxItems": 0 }
      }
    },
    "resolutionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_id", "sequence", "occurred_at", "previous_record_hash", "workspace_id", "repository_revision_before", "proposal_id", "proposal_checksum", "base_revision_id", "committed_revision_id", "committed_payload_checksum", "source_draft_id", "source_draft_checksum", "diff_format", "diff_version", "change_count", "diff_checksum", "reviewer", "rationale", "validation", "diagnostics_before", "diagnostics_after", "identity_assurance", "approval_mode", "record_hash"],
      "properties": {
        "record_id": { "type": "string", "minLength": 1 },
        "sequence": { "type": "integer", "minimum": 1 },
        "occurred_at": { "type": "string", "format": "date-time" },
        "previous_record_hash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "workspace_id": { "type": "string", "minLength": 1 },
        "repository_revision_before": { "type": "integer", "minimum": 1 },
        "proposal_id": { "type": "string", "minLength": 1 },
        "proposal_checksum": { "$ref": "#/$defs/checksum" },
        "base_revision_id": { "type": "string", "minLength": 1 },
        "committed_revision_id": { "type": "string", "minLength": 1 },
        "committed_payload_checksum": { "$ref": "#/$defs/checksum" },
        "source_draft_id": { "type": "string", "minLength": 1 },
        "source_draft_checksum": { "$ref": "#/$defs/checksum" },
        "diff_format": { "const": "jarbou3i-canonical-diff" },
        "diff_version": { "const": 1 },
        "change_count": { "type": "integer", "minimum": 1 },
        "diff_checksum": { "$ref": "#/$defs/checksum" },
        "reviewer": { "$ref": "#/$defs/reviewer" },
        "rationale": { "type": "string", "minLength": 1 },
        "validation": { "$ref": "#/$defs/resolutionValidation" },
        "diagnostics_before": {},
        "diagnostics_after": {},
        "identity_assurance": { "const": "local_assertion" },
        "approval_mode": { "const": "explicit_local_confirmation" },
        "record_hash": { "$ref": "#/$defs/checksum" }
      }
    },
    "resolutionLedger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "format_version", "created_at", "head_record_hash", "records"],
      "properties": {
        "format": { "const": "jarbou3i-resolution-ledger" },
        "format_version": { "const": 1 },
        "created_at": { "type": "string", "format": "date-time" },
        "head_record_hash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "records": { "type": "array", "items": { "$ref": "#/$defs/resolutionRecord" } }
      }
    }
  }
}
